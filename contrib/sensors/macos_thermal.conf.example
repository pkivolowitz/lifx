# GlowUp macOS thermal sensor — example config.
#
# Deploy location on each Mac: ~/macos_thermal.conf
# Read by: contrib/sensors/macos_thermal_sensor.py
#
# All sections and keys are optional — anything missing falls back to
# the module defaults.

[mqtt]
# GlowUp canonical broker — Pi 5 "glowup" hub.  See reference_project_state.md.
broker = 10.0.0.214
port = 1883

[sensor]
# Publish interval in seconds.
interval = 30

# Override the node identifier.  Blank = use short lowercase hostname.
# For Daedalus we set this explicitly so the dashboard label matches the
# fleet's canonical name regardless of macOS hostname drift.
node_id = daedalus
