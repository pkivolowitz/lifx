{
  "_comment_top": "GlowUp site configuration template. Copy to /etc/glowup/site.json (or ~/.glowup/site.json on a dev Mac) and replace every <placeholder> with your real value, or remove the key to disable the optional feature it controls.  Loaded by glowup_site.py at module import; programs read from glowup_site.site.",

  "schema_version": 1,

  "hub_broker": "<hub host or IP — REQUIRED for any service that publishes to the hub>",
  "hub_port": 1883,

  "_comment_optional": "Everything below is optional — remove a key to disable its feature.",

  "broker_2": "<secondary broker host, if you run a per-room mosquitto>",

  "zigbee_service_url": "<full URL of glowup-zigbee-service HTTP API, e.g. http://broker-2.local:8422 — REQUIRED for voice coordinator plug commands>",

  "node_ips": {
    "_comment": "node_id -> IP. Optional. Used by the hub dashboard's thermal page to enrich rows with each host's IP. Lowercase node_id keys (matches MQTT publishers).",
    "<node-id>": "<host or IP>"
  },

  "postgres_dsn": "<postgresql://user:pass@host:5432/db — for zigbee_service history>",

  "printer": "<printer host or IP — for the printer adapter>",

  "_comment_contact": "Operator contact email used for any external API that requires a callback — currently NWS (api.weather.gov) for the voice coordinator's weather source. NWS rate-limits or blocks opaque User-Agents; supplying a real email lets them reach you before pulling the plug. Optional: omit and the User-Agent will be name-only, accepting NWS's possibly-degraded service.",
  "contact_email": "<operator contact email, e.g. ops@example.com>",

  "_comment_maritime_reference": "Reference point for the /maritime dashboard's vessel-table side panel — drives the distance column (nautical miles) and the closest-N range filter (25/50/100/All). The lat/lon do the math; postal_code and country are display labels only (no runtime geocoding). Omit the whole block to disable distance/range — the side panel still works, it just hides the range control and shows '—' in the distance column.",
  "maritime_reference": {
    "postal_code": "<your postal code, e.g. 36602>",
    "country":     "<ISO-2 country code, e.g. US>",
    "lat":         "<reference latitude in WGS-84 decimal degrees>",
    "lon":         "<reference longitude in WGS-84 decimal degrees>"
  },

  "_comment_maritime_buoys": "NDBC stations to scrape every 5 minutes via maritime/buoy_scraper.py (publishes to glowup/maritime/buoy/<id>; consumed by BuoyBuffer for the live map layer and BuoyLogger for postgres history backing /buoys/<station>). Each entry needs at minimum 'id'; lat/lon are required for a marker on the /maritime map; name is a friendly display label. Find station ids and lat/lons on each station's NDBC page (https://www.ndbc.noaa.gov/station_page.php?station=<id>). Stations without a realtime2 file (CMAN-only or decommissioned) are skipped silently after one warning — safe to leave configured.",
  "maritime_buoys": [
    {"id": "<NDBC station id, e.g. 42012>", "name": "<friendly name>", "lat": "<lat>", "lon": "<lon>"}
  ],

  "_comment_traffic_radius_km": "Half-side of the bounding box used by the /roads page's TomTom incidents query, centered on maritime_reference. 50 km covers a metro-sized area; raise for a wider region or lower to stay tighter on the immediate viewport. Cache hit rate is highest when this matches actual viewing — operators rarely pan far from home, so a fixed bbox + caching beats per-viewport queries on a free-tier budget.",
  "traffic_radius_km": 50
}
