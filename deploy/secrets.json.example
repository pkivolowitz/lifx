{
  "_comment_top": "GlowUp secrets overlay — sensitive values that don't belong in the rendered site.json. Same JSON shape as site.json; loaded by glowup_site.py AFTER site.json and merged on top, so any key here wins over a matching key in site.json. Copy to /etc/glowup/secrets.json (root-owned, mode 0640, group readable by the service user) and fill in. NEVER commit a populated copy of this file. .gitignore covers /secrets.json/i — keep it that way.",

  "schema_version": 1,

  "_comment_postgres": "Connection string for the GlowUp postgres jail. Required only on hosts that run zigbee_service or other history-writing services. Empty / unset = the dependent service crashes at startup with a useful message.",
  "postgres_dsn": "<postgresql://user:password@host:5432/database>",

  "_comment_tomtom": "TomTom Maps & Traffic API key — drives the /roads dashboard's flow-tile overlay and incidents pins (also rendered on /traffic).  Free tier is 2,500 transactions/day; the hub-side TrafficBuffer caches both endpoints so a long-lived session stays well under that. Sign up at developer.tomtom.com → create a key with Maps API + Traffic API products attached.  Empty / unset = /roads and the roads layer on /traffic show no data, every other dashboard works normally.",
  "tomtom_api_key": "<TomTom Maps & Traffic API key>"
}
