# Deploy stamp written by glowup-infra/deploy/scripts/deploy.sh on each
# fleet host after a successful git-based deploy. Untracked so it
# survives `git reset --hard staging/master`; gitignored so it doesn't
# show as dirty on dev workstations that ever happen to write one.
DEPLOYED

